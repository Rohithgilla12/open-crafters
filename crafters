#!/usr/bin/env bash
# crafters — the open-crafters launcher.
#
# A thin, dependency-free wrapper around the grader so you can go from clone to
# coding in one command:
#
#   crafters start wal          scaffold a solution for the WAL challenge & grade it
#   crafters test               re-grade the solution in the current directory
#   crafters status             show your progress checklist
#   crafters list               list all challenges and their stages
#
# It finds (or builds, or downloads) the grader for you. No long flags, no
# remembering which --challenge goes with which --program.

set -euo pipefail

# --- locate the open-crafters content (challenges/, tester/) ---
# The script lives either at a repo root (a clone) or at <home>/bin/crafters
# (installed). Resolve symlinks so we find our true location either way.
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"; src="$(readlink "$src")"
  case "$src" in /*) ;; *) src="$dir/$src" ;; esac
done
self_dir="$(cd -P "$(dirname "$src")" && pwd)"

if [ -d "$self_dir/challenges" ] && [ -d "$self_dir/tester" ]; then
  CRAFTERS_HOME="$self_dir"                            # running from a clone
elif [ -d "$self_dir/../repo/challenges" ]; then
  CRAFTERS_HOME="$(cd "$self_dir/../repo" && pwd)"      # installed: <home>/bin → <home>/repo
elif [ -n "${CRAFTERS_HOME:-}" ] && [ -d "$CRAFTERS_HOME/challenges" ]; then
  :                                                    # honor an explicit override
elif [ -d "$HOME/.open-crafters/repo/challenges" ]; then
  CRAFTERS_HOME="$HOME/.open-crafters/repo"             # default install location
else
  echo "crafters: can't find the open-crafters content." >&2
  echo "Run this from a clone of the repo, set CRAFTERS_HOME, or install with:" >&2
  echo "  curl -fsSL https://raw.githubusercontent.com/Rohithgilla12/open-crafters/main/install.sh | sh" >&2
  exit 1
fi

die() { echo "crafters: $*" >&2; exit 1; }

# --- find the grader binary, building from source as a last resort ---
find_grader() {
  local c
  for c in \
    "$self_dir/crafters-tester" \
    "$HOME/.open-crafters/bin/crafters-tester" \
    "$CRAFTERS_HOME/bin/crafters-tester" \
    "$CRAFTERS_HOME/tester/tester"; do
    if [ -x "$c" ]; then echo "$c"; return 0; fi
  done
  if command -v go >/dev/null 2>&1; then
    echo "→ building the grader (one time)…" >&2
    ( cd "$CRAFTERS_HOME/tester" && go build -o tester ./cmd/tester ) >&2
    echo "$CRAFTERS_HOME/tester/tester"; return 0
  fi
  die "no grader binary found and Go isn't installed. Install Go, or run install.sh to download a prebuilt grader."
}

grader() { "$(find_grader)" "$@"; }

# --- resolve a (possibly fuzzy) challenge name to a full slug ---
resolve_challenge() {
  local q="$1" matches=() slug
  for d in "$CRAFTERS_HOME"/challenges/*/; do
    slug="$(basename "$d")"
    if [ "$slug" = "$q" ] || [ "$slug" = "build-your-own-$q" ]; then
      echo "$slug"; return 0
    fi
  done
  for d in "$CRAFTERS_HOME"/challenges/*/; do
    slug="$(basename "$d")"
    case "$slug" in *"$q"*) matches+=("$slug");; esac
  done
  if [ "${#matches[@]}" -eq 1 ]; then
    echo "${matches[0]}"; return 0
  elif [ "${#matches[@]}" -gt 1 ]; then
    die "'$q' is ambiguous — matches: ${matches[*]}"
  fi
  die "no challenge matches '$q'. Try: crafters list"
}

solution_slug() {
  local dir="$1"
  [ -f "$dir/your_program.sh" ] || die "'$dir' isn't a solution directory (no your_program.sh). Run 'crafters start <challenge>' first, then cd into it."
  if [ -f "$dir/.open-crafters/challenge" ]; then
    cat "$dir/.open-crafters/challenge"
  else
    die "can't tell which challenge '$dir' is for. Re-create it with 'crafters start <challenge>'."
  fi
}

cmd_start() {
  [ $# -ge 1 ] || die "usage: crafters start <challenge> [dir] [--lang python|go]"
  local query="$1"; shift
  local lang="python" dest=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --lang) lang="${2:-}"; shift 2;;
      --lang=*) lang="${1#--lang=}"; shift;;
      *) dest="$1"; shift;;
    esac
  done
  local slug; slug="$(resolve_challenge "$query")"
  local src="$CRAFTERS_HOME/challenges/$slug/starters/$lang"
  [ -d "$src" ] || die "no '$lang' starter for $slug (available: $(ls "$CRAFTERS_HOME/challenges/$slug/starters" | tr '\n' ' '))"
  [ -n "$dest" ] || dest="my-${slug#build-your-own-}"
  [ -e "$dest" ] && die "'$dest' already exists — pass a different directory name."

  cp -r "$src" "$dest"
  mkdir -p "$dest/.open-crafters"
  echo "$slug" > "$dest/.open-crafters/challenge"
  chmod +x "$dest/your_program.sh" 2>/dev/null || true

  echo "✓ created ./$dest from the $lang starter for \"$slug\""
  echo "  protocol: $CRAFTERS_HOME/challenges/$slug/PROTOCOL.md"
  echo
  grader --challenge "$slug" --program "$dest/your_program.sh" || true
  echo
  echo "Next: cd $dest, edit your code, then run 'crafters test' to grade again."
}

cmd_test() {
  local dir="${1:-.}"; local slug; slug="$(solution_slug "$dir")"
  grader --challenge "$slug" --program "$dir/your_program.sh"
}

cmd_status() {
  local dir="${1:-.}"; local slug; slug="$(solution_slug "$dir")"
  grader --challenge "$slug" --program "$dir/your_program.sh" --status
}

cmd_list() { grader --list; }

usage() {
  cat <<'EOF'
crafters — open-crafters launcher

USAGE
  crafters start <challenge> [dir] [--lang python|go]   scaffold a solution and grade it
  crafters test  [dir]                                  re-grade (resumes where you left off)
  crafters status [dir]                                 show the progress checklist
  crafters list                                         list challenges and stages

EXAMPLES
  crafters start wal          # 'wal' fuzzy-matches build-your-own-wal
  crafters start queue --lang go
  cd my-wal && crafters test

<challenge> accepts a fuzzy name (wal, queue, temporal) or a full slug.
[dir] defaults to the current directory for test/status.
EOF
}

case "${1:-}" in
  start)  shift; cmd_start "$@";;
  test)   shift; cmd_test "$@";;
  status) shift; cmd_status "$@";;
  list)   shift; cmd_list "$@";;
  ""|-h|--help|help) usage;;
  *) echo "crafters: unknown command '$1'" >&2; echo >&2; usage; exit 1;;
esac
